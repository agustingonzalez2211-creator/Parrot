{
  "name": "parrot",
  "version": "1.0.0",
  "description": "Screen-to-AI-Skill Generator",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && node_modules/.bin/esbuild src/renderer/renderer.ts --bundle --outfile=dist/renderer/renderer.js --platform=browser && cp src/renderer/index.html dist/renderer/index.html",
    "start": "pnpm build && ELECTRON_OZONE_PLATFORM_HINT=x11 electron .",
    "dev": "tsc --watch & sleep 2 && electron . --enable-logging"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "dotenv": "^17.4.2",
    "electron": "^36.0.0",
    "playwright": "^1.50.0",
    "yaml": "^2.7.0"
  }
}
